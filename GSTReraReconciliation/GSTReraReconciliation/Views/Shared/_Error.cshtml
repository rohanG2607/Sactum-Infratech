@model System.Web.Mvc.HandleErrorInfo
@{
    ViewBag.Title = "Error";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
                    <h1 class="mt-3 fw-bold">Something went wrong</h1>
                    <p class="text-muted mt-3">
                        An unexpected error has occurred. Please try again later or contact support
                        if the problem persists.
                    </p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-3" id="errorHomeBtn">
                        <i class="bi bi-house-door me-1"></i>Return to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
